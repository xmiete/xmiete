{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xmiete.org/schemas/xmiete_schema.json",
  "$comment": "Licensed under Creative Commons Attribution 4.0 International (CC BY 4.0). See LICENSE-SPECIFICATION for details.",
  "title": "XMiete Core Schema",
  "description": "A modular standard for digital rental deposits (BGB § 551 compliant).",
  "type": "object",
  "required": [
    "meta",
    "tenant",
    "landlord",
    "property",
    "deposit"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "timestamp"],
      "properties": {
        "version": { "type": "string", "example": "1.0.0" },
        "timestamp": { "type": "string", "format": "date-time" },
        "external_id": { "type": "string", "description": "ID from the calling system" }
      }
    },
    "tenant": {
      "type": "object",
      "required": ["first_name", "last_name", "email"],
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "tax_id": { 
          "type": "string", 
          "pattern": "^[0-9]{11}$",
          "description": "German 11-digit Steuer-ID for tax logic."
        },
        "eid_status": {
          "type": "string",
          "enum": ["NOT_STARTED", "IN_PROGRESS", "VERIFIED", "FAILED"],
          "default": "NOT_STARTED"
        },
        "wallet_metadata": { "$ref": "#/definitions/wallet_metadata" },
        "address": { "$ref": "#/definitions/address" }
      }
    },
    "landlord": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Name of landlord or property management" },
        "type": { "type": "string", "enum": ["PRIVATE", "COMMERCIAL"] },
        "iban": { "type": "string", "pattern": "^[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}$" }
      }
    },
    "property": {
      "type": "object",
      "required": ["address"],
      "properties": {
        "address": { "$ref": "#/definitions/address" },
        "unit_id": { "type": "string", "description": "Specific apartment/unit identifier" }
      }
    },
    "deposit": {
      "type": "object",
      "required": ["amount", "currency", "type", "lifecycle_state"],
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "EUR" },
        "type": { 
          "type": "string", 
          "enum": ["CASH_EQUIVALENT", "BANK_GUARANTEE", "INSURANCE"] 
        },
        "lifecycle_state": {
          "type": "string",
          "enum": ["REQUESTED", "IDENTIFIED", "FUNDED", "PLEDGED", "RELEASED", "CLAIMED", "CLOSED"]
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["state", "timestamp"],
            "properties": {
              "state": { 
                "type": "string",
                "enum": ["REQUESTED", "IDENTIFIED", "FUNDED", "PLEDGED", "RELEASED", "CLAIMED", "CLOSED"]
              },
              "timestamp": { "type": "string", "format": "date-time" },
              "actor": { "type": "string", "description": "Entity that triggered the transition (e.g., TENANT, BANK, LANDLORD)" },
              "comment": { "type": "string" },
              "signature": { "type": "string", "description": "JWS (JSON Web Signature) for non-repudiation of critical transitions." }
            }
          }
        }
      }
    },
    "pledge": {
      "type": "object",
      "description": "BGB § 551 specific data",
      "properties": {
        "pledge_date": { "type": "string", "format": "date" },
        "legal_reference": { "type": "string", "default": "BGB § 551" },
        "is_confirmed_by_bank": { "type": "boolean", "default": false }
      }
    },
    "provider": {
      "type": "object",
      "description": "Information about the bank, insurer, or fintech platform providing the deposit.",
      "required": ["provider_type", "executing_entity"],
      "properties": {
        "provider_type": {
          "type": "string",
          "enum": ["BANK_SYSTEM_PARTNER", "INSURANCE_BROKER", "DIRECT_BANK", "FINTECH_PLATFORM"]
        },
        "executing_entity": { 
          "type": "string", 
          "description": "The legal entity holding the funds or issuing the guarantee (e.g., Aareal Bank, Volksbank, Instabank)."
        },
        "brand_name": { 
          "type": "string", 
          "description": "The brand or platform name facing the user (e.g., GetMomo, PlusForta, Smartmiete)."
        },
        "provider_id": { "type": "string", "description": "Internal identifier for the provider" },
        "insurance_policy_number": { "type": "string" },
        "custom_fields": { "type": "object" }
      }
    }
  },
  "definitions": {
    "wallet_metadata": {
      "type": "object",
      "description": "eIDAS 2.0 / EUDI-Wallet credential metadata for tenant identity verification.",
      "properties": {
        "issuer": {
          "type": "string",
          "description": "Human-readable name of the credential issuer (e.g., 'Bundesdruckerei GmbH')."
        },
        "issuer_id": {
          "type": "string",
          "description": "URI or DID identifying the credential issuer (e.g., 'https://pid.bundesdruckerei.de' or 'did:web:bundesdruckerei.de')."
        },
        "wallet_provider": {
          "type": "string",
          "description": "Identifier of the EUDI Wallet provider app (e.g., 'bundesdruckerei', 'lissi', 'sprind')."
        },
        "credential_type": {
          "type": "string",
          "enum": ["PID", "EAA", "QEAA", "MDL"],
          "description": "EUDI credential type: PID (Person Identification Data), EAA/QEAA (Electronic Attestation of Attributes), or MDL (mobile Driving License)."
        },
        "credential_format": {
          "type": "string",
          "enum": ["vc+sd-jwt", "mso_mdoc", "ldp_vc"],
          "description": "Credential encoding format per OpenID4VCI / EUDI ARF."
        },
        "assurance_level": {
          "type": "string",
          "enum": ["low", "substantial", "high"],
          "description": "eIDAS Level of Assurance per Article 8 of Regulation (EU) No 910/2014 as amended by eIDAS 2.0."
        },
        "presentation_id": {
          "type": "string",
          "description": "Opaque reference to the Verifiable Presentation submitted during verification."
        },
        "issuing_country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code of the credential issuer."
        },
        "verified_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the EUDI Wallet presentation was verified by the relying party."
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "Expiry timestamp of the wallet credential."
        }
      }
    },
    "address": {
      "type": "object",
      "required": ["street", "zip", "city", "country"],
      "properties": {
        "street": { "type": "string" },
        "zip": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string", "pattern": "^[A-Z]{2}$", "default": "DE" }
      }
    }
  }
}
